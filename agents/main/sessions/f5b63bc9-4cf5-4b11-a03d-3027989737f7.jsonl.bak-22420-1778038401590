ert.type || '';\n                newHTML += `\n                    <div class=\"alert-item ${alertClass}\">\n                        <div class=\"alert-agent\">${alert.from} → ${alert.to}</div>\n                        <div class=\"alert-text\">${alert.message}</div>\n                        <div class=\"alert-time\">${alert.time}</div>\n                    </div>\n                `;\n            });\n            \n            container.innerHTML = newHTML;\n        }\n        \n        function markDeployingAgents(pendingDeploys) {\n            pendingDeploys.forEach(agentName => {\n                const agentId = agentIds[agentName];\n                if (agentId) {\n                    const card = document.getElementById(agentId + '-card');\n                    const btn = document.getElementById(agentId + '-deploy');\n                    if (card) card.classList.add('deploying');\n                    if (btn) {\n                        btn.disabled = true;\n                        btn.innerHTML = '<span>⏳</span><span>Deploying...</span>';\n                    }\n                }\n            });\n        }\n        \n        // ==================== DEPLOY REQUESTS ====================\n        // When user clicks deploy, write request to state file\n        \n        async function requestDeploy(agentName) {\n            try {\n                // Update UI immediately\n                const agentId = agentIds[agentName];\n                const card = document.getElementById(agentId + '-card');\n                const btn = document.getElementById(agentId + '-deploy');\n                \n                if (card) card.classList.add('deploying');\n                if (btn) {\n                    btn.disabled = true;\n                    btn.innerHTML = '<span>⏳</span><span>Deploying...</span>';\n                }\n                \n                // Write deploy request to trigger file\n                await writeDeployRequest(agentName);\n                \n      